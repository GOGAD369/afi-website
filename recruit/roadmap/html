<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Afi Digital — WhatsApp Automation Business Roadmap</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap');

:root {
  --green: #00c853;
  --green-dim: #00c85315;
  --green-mid: #00c85340;
  --black: #0a0a0a;
  --deep: #111;
  --card: #161616;
  --border: #222;
  --text: #e8e8e8;
  --muted: #888;
  --white: #fff;
}

* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
body { background:var(--black); color:var(--text); font-family:'Inter', sans-serif; line-height:1.6; }

/* HERO */
.hero {
  padding:60px 5% 40px;
  border-bottom:1px solid var(--border);
  position:relative;
  overflow:hidden;
}
.hero::before {
  content:'';
  position:absolute; top:0; left:0; right:0; bottom:0;
  background:radial-gradient(ellipse 80% 60% at 50% 0%, #00c85310, transparent);
  pointer-events:none;
}
.badge {
  display:inline-flex; align-items:center; gap:6px;
  background:var(--green-dim); border:1px solid var(--green-mid);
  padding:5px 12px; border-radius:100px;
  font-size:11px; font-weight:600; color:var(--green);
  letter-spacing:1px; text-transform:uppercase; margin-bottom:20px;
}
.dot-pulse { width:6px; height:6px; border-radius:50%; background:var(--green); animation:pulse 1.5s infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }
.hero h1 { font-size:clamp(28px,4vw,52px); font-weight:800; line-height:1.1; margin-bottom:12px; }
.hero h1 em { font-style:italic; color:var(--green); }
.hero p { font-size:15px; color:var(--muted); max-width:600px; margin-bottom:32px; }
.hero-meta { display:flex; gap:32px; flex-wrap:wrap; }
.hero-meta-item .label { font-size:11px; color:var(--muted); text-transform:uppercase; letter-spacing:1px; }
.hero-meta-item .value { font-size:18px; font-weight:700; color:var(--white); margin-top:2px; }

/* TOC */
.toc {
  padding:32px 5%;
  border-bottom:1px solid var(--border);
  display:flex; gap:8px; flex-wrap:wrap;
}
.toc a {
  padding:6px 14px; background:var(--card); border:1px solid var(--border);
  border-radius:100px; font-size:12px; color:var(--muted);
  text-decoration:none; transition:0.2s; white-space:nowrap;
}
.toc a:hover { border-color:var(--green); color:var(--green); }

/* SECTIONS */
.section { padding:48px 5%; border-bottom:1px solid var(--border); }
.section-tag { font-size:10px; font-weight:700; color:var(--green); letter-spacing:2px; text-transform:uppercase; margin-bottom:10px; }
.section h2 { font-size:clamp(22px,3vw,36px); font-weight:800; margin-bottom:8px; }
.section h2 em { color:var(--green); font-style:italic; }
.section > p { font-size:14px; color:var(--muted); max-width:700px; margin-bottom:32px; }

/* PHASE TIMELINE */
.phases { display:flex; flex-direction:column; gap:0; }
.phase {
  display:grid; grid-template-columns:200px 1fr;
  gap:0; position:relative;
}
.phase::before {
  content:'';
  position:absolute; left:199px; top:0; bottom:0;
  width:1px; background:var(--border);
}
.phase-left {
  padding:24px 32px 24px 0;
  text-align:right; flex-shrink:0;
}
.phase-num {
  font-family:'JetBrains Mono', monospace;
  font-size:11px; color:var(--green); font-weight:600;
  letter-spacing:1px; margin-bottom:6px;
}
.phase-name { font-size:15px; font-weight:700; color:var(--white); }
.phase-time { font-size:11px; color:var(--muted); margin-top:4px; }
.phase-dot {
  position:absolute; left:192px; top:28px;
  width:16px; height:16px; border-radius:50%;
  background:var(--green); border:3px solid var(--black);
  z-index:1;
}
.phase-right { padding:24px 0 24px 40px; }
.phase-right p { font-size:13.5px; color:var(--muted); margin-bottom:14px; }
.phase-tasks { display:flex; flex-direction:column; gap:8px; }
.task {
  display:flex; align-items:flex-start; gap:10px;
  padding:10px 14px; background:var(--card);
  border:1px solid var(--border); border-radius:10px;
  font-size:13px; transition:0.2s;
}
.task:hover { border-color:var(--green-mid); }
.task-icon { font-size:14px; flex-shrink:0; margin-top:1px; }
.task-text { flex:1; }
.task-text strong { color:var(--white); display:block; margin-bottom:2px; }
.task-text span { font-size:12px; color:var(--muted); }
.task-badge {
  font-size:10px; padding:2px 7px; border-radius:100px; font-weight:600; flex-shrink:0;
}
.badge-now { background:#1a3d1a; color:var(--green); }
.badge-soon { background:#3d2a00; color:#f59e0b; }
.badge-later { background:#1a1a2e; color:#818cf8; }

/* CLIENT FLOW */
.flow-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:16px; }
.flow-card {
  background:var(--card); border:1px solid var(--border);
  border-radius:14px; padding:20px; position:relative;
  transition:0.2s;
}
.flow-card:hover { border-color:var(--green-mid); }
.flow-step {
  font-family:'JetBrains Mono', monospace;
  font-size:11px; color:var(--green); font-weight:600; margin-bottom:10px;
}
.flow-card h4 { font-size:14px; font-weight:700; color:var(--white); margin-bottom:6px; }
.flow-card p { font-size:12px; color:var(--muted); line-height:1.5; }
.flow-time {
  display:inline-block; margin-top:10px;
  font-size:10px; padding:2px 8px; border-radius:100px;
  background:var(--green-dim); color:var(--green); font-weight:600;
}
.flow-arrow {
  display:flex; align-items:center; justify-content:center;
  color:var(--border); font-size:20px; padding-top:30px;
}

/* TECH STACK */
.stack-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:12px; }
.stack-item {
  background:var(--card); border:1px solid var(--border);
  border-radius:12px; padding:16px;
}
.stack-item .s-icon { font-size:24px; margin-bottom:8px; }
.stack-item .s-name { font-size:13px; font-weight:700; color:var(--white); margin-bottom:4px; }
.stack-item .s-use { font-size:11px; color:var(--muted); }
.stack-item .s-status { margin-top:8px; font-size:10px; padding:2px 7px; border-radius:100px; font-weight:600; display:inline-block; }
.s-done { background:#1a3d1a; color:var(--green); }
.s-needed { background:#3d2a00; color:#f59e0b; }
.s-future { background:#1a1a2e; color:#818cf8; }

/* AI SETUP TABLE */
.ai-table { width:100%; border-collapse:collapse; }
.ai-table th {
  text-align:left; padding:10px 14px;
  font-size:11px; font-weight:700; color:var(--muted);
  text-transform:uppercase; letter-spacing:0.5px;
  border-bottom:1px solid var(--border);
}
.ai-table td {
  padding:12px 14px; font-size:13px;
  border-bottom:1px solid #1a1a1a; vertical-align:top;
}
.ai-table tr:last-child td { border-bottom:none; }
.ai-table tr:hover td { background:#111; }
.ai-table td:first-child { color:var(--white); font-weight:600; }
.ai-table td:nth-child(2) { color:var(--muted); }
.ai-table td:nth-child(3) { color:#f59e0b; font-size:12px; }
.ai-table td:last-child { color:var(--green); font-family:'JetBrains Mono',monospace; font-size:11px; }

/* CLIENT CATEGORIES */
.cat-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:12px; }
.cat-card {
  background:var(--card); border:1px solid var(--border);
  border-radius:12px; padding:18px;
}
.cat-icon { font-size:28px; margin-bottom:10px; }
.cat-name { font-size:14px; font-weight:700; color:var(--white); margin-bottom:4px; }
.cat-desc { font-size:12px; color:var(--muted); margin-bottom:10px; line-height:1.5; }
.cat-kb { font-size:11px; color:var(--green); }
.cat-kb::before { content:'📚 KB: '; }

/* SOP STEPS */
.sop-list { display:flex; flex-direction:column; gap:12px; }
.sop-item {
  display:flex; gap:16px; align-items:flex-start;
  background:var(--card); border:1px solid var(--border);
  border-radius:12px; padding:16px;
}
.sop-num {
  width:32px; height:32px; border-radius:50%;
  background:linear-gradient(135deg,var(--green),#008c38);
  display:flex; align-items:center; justify-content:center;
  font-size:12px; font-weight:800; color:#000; flex-shrink:0;
}
.sop-content h4 { font-size:14px; font-weight:700; color:var(--white); margin-bottom:4px; }
.sop-content p { font-size:12.5px; color:var(--muted); }
.sop-time { font-size:10px; color:var(--green); font-weight:600; margin-top:6px; font-family:'JetBrains Mono',monospace; }

/* PRICING */
.pricing-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:16px; }
.price-card {
  background:var(--card); border:1px solid var(--border);
  border-radius:14px; padding:24px;
}
.price-card.featured { border-color:var(--green); }
.price-tier { font-size:11px; color:var(--muted); text-transform:uppercase; letter-spacing:1px; margin-bottom:8px; }
.price-amount { font-size:32px; font-weight:800; color:var(--white); }
.price-amount small { font-size:13px; color:var(--muted); font-weight:400; }
.price-desc { font-size:12px; color:var(--muted); margin:8px 0 16px; }
.price-features { list-style:none; display:flex; flex-direction:column; gap:8px; }
.price-features li { font-size:12px; color:var(--muted); display:flex; gap:6px; }
.price-features li::before { content:'✓'; color:var(--green); font-weight:700; flex-shrink:0; }

/* CODE BLOCK */
.code-block {
  background:#0d0d0d; border:1px solid var(--border);
  border-radius:12px; padding:20px;
  font-family:'JetBrains Mono', monospace;
  font-size:12px; color:#a3e635;
  overflow-x:auto; line-height:1.7; margin-top:16px;
}
.code-block .comment { color:#555; }
.code-block .key { color:#60a5fa; }
.code-block .val { color:#a3e635; }
.code-block .str { color:#f59e0b; }

/* CHECKLIST */
.checklist { display:flex; flex-direction:column; gap:8px; }
.check-item {
  display:flex; align-items:center; gap:10px;
  padding:10px 14px; background:var(--card);
  border:1px solid var(--border); border-radius:8px;
  font-size:13px; color:var(--text);
}
.check-item .ci { font-size:16px; }
.check-item.done { border-color:var(--green-mid); }
.check-item.done::after { content:'✅'; margin-left:auto; }
.check-item.pending::after { content:'⏳'; margin-left:auto; }
.check-item.todo::after { content:'⬜'; margin-left:auto; }

/* FOOTER */
footer {
  padding:32px 5%;
  border-top:1px solid var(--border);
  display:flex; justify-content:space-between; align-items:center;
  flex-wrap:wrap; gap:16px;
}
.footer-brand { font-size:16px; font-weight:800; color:var(--green); }
.footer-info { font-size:12px; color:var(--muted); }

@media(max-width:768px) {
  .phase { grid-template-columns:1fr; }
  .phase::before { display:none; }
  .phase-dot { display:none; }
  .phase-left { text-align:left; padding:16px 0 0; }
  .phase-right { padding:12px 0 24px; }
  .toc { overflow-x:auto; flex-wrap:nowrap; }
}
</style>
</head>
